# ===========================
# SpiderNet - .gitignore
# ===========================

# Large data files (too big for GitHub)
data/
*.csv

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Anaconda project files
anaconda_projects/

# Unnecessary personal/media files
*.jpeg
*.jpg
*.pdf
Untitled.ipynb

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyd

# Virtual environments
.env
venv/
env/
.venv/

# OS files
.DS_Store
Thumbs.db
desktop.ini

# IDE/editor files
.vscode/
.idea/
*.suo
*.user
